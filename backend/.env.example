# ──────────────────────────────────────────────
#  PromptNest — Backend environment template
#  Copy to `.env` and fill in real values.
# ──────────────────────────────────────────────

# ── Required ──────────────────────────────────
DATABASE_URL=postgresql://postgres:change-me@localhost:5432/promptnest
SECRET_KEY=generate-a-64-character-random-secret

# ── Optional (defaults shown; uncomment to override) ──
# ENVIRONMENT=development          # set to "production" to enforce prod safety checks
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=5    # access token lives in browser memory only; keep short
# REFRESH_TOKEN_EXPIRE_DAYS=30     # persistent ("remember me") session lifetime
# IDLE_TIMEOUT_MINUTES=30          # ephemeral session dies after this much inactivity
# EPHEMERAL_ABSOLUTE_CAP_HOURS=12  # hard ceiling on an ephemeral session regardless of activity
# COOKIE_SECURE=false              # MUST be true in production (HTTPS)
# TRUST_PROXY=false                # true only when behind a reverse proxy you control
#                                  # (needed for correct client IP in rate limits + session metadata)
# ENABLE_DOCS=true                 # Swagger/ReDoc; auto-off in production
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000   # also the trusted origins for CSRF
# FRONTEND_URL=http://127.0.0.1:3000
# OAUTH_FRONTEND_CALLBACK_URL=http://127.0.0.1:3000/oauth/callback

# ── OAuth (optional) ──────────────────────────
# Leave blank to keep a provider disabled. Register these exact callback URLs
# in the provider console when adding credentials:
#   Google -> http://127.0.0.1:8000/api/v1/auth/oauth/google/callback
#   GitHub -> http://127.0.0.1:8000/api/v1/auth/oauth/github/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Override redirect URIs only if the backend is not on 127.0.0.1:8080
# GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/v1/auth/oauth/google/callback
# GITHUB_REDIRECT_URI=http://127.0.0.1:8000/api/v1/auth/oauth/github/callback
